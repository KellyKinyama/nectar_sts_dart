# Committed template — copy to .env and edit for your environment.
# Loaded by lib/src/server/app_env.dart. Process env vars override
# any value here (so the integration test runner can still inject
# explicit overrides via Symfony Process).

# --- HTTP server ------------------------------------------------------
PORT=8787
HOST=127.0.0.1

# --- Crypto -----------------------------------------------------------
# 16 hex chars = 8-byte DES vending key. Replace with your real key in
# .env — the value below is the built-in demo key and is NOT safe for
# production use.
VENDING_KEY_HEX=0123456789ABCDEF

# Bearer required on every /v1/* request. Leave blank to disable auth.
NECTAR_API_TOKEN=change-me

# --- Storage (JSON-file mode) -----------------------------------------
VENDING_LOG_FILE=vending.json
METER_REGISTRY_FILE=meters.json

# --- Storage (MySQL mode, optional) -----------------------------------
# Uncomment STS_DB_HOST to switch from JSON files to the shared MySQL
# database owned by the Laravel sts-vending dashboard.
# STS_DB_HOST=127.0.0.1
# STS_DB_PORT=3306
# STS_DB_DATABASE=sts_vending
# STS_DB_USERNAME=root
# STS_DB_PASSWORD=
# STS_DB_SSLMODE=require
# STS_DB_POOL_SIZE=5
